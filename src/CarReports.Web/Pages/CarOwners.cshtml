@page
@model CarOwnersModel
@{
    ViewData["Title"] = "Car Owners";
    ViewData["MainClass"] = "container-wide";
}

<p><a asp-page="/Index" class="back-link">&larr; Back</a></p>

<div class="page-head">
    <h1>Car Owners</h1>
    <p class="lead">@Model.Vehicles.Count active vehicles. Click a plate to edit.</p>
</div>

<div class="table-toolbar">
    <input type="search" id="vehicle-filter" placeholder="Filter by code, name, plate, brand…" autocomplete="off" />
    <span id="vehicle-filter-count" class="filter-count">@Model.Vehicles.Count shown</span>
    <button type="button" id="btn-add-vehicle" class="btn-primary-sm">+ Add Vehicle</button>
    <span id="vehicle-status" class="owner-status" role="status" aria-live="polite"></span>
</div>

<div class="table-scroll table-scroll-wide">
    <table class="vehicle-table" id="vehicle-table">
        <thead>
            <tr>
                <th class="col-code">Code</th>
                <th class="col-name">Full Name (TH)</th>
                <th class="col-type">Type</th>
                <th class="col-card">Card</th>
                <th class="col-plate">Plate</th>
                <th class="col-province">Province</th>
                <th class="col-brand">Brand</th>
                <th class="col-model">Model</th>
                <th class="col-color">Color</th>
                <th class="col-actions">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Vehicles)
            {
                <tr data-id="@v.Id" data-employee-code="@v.EmployeeCode">
                    <td class="col-code">@v.EmployeeCode</td>
                    <td class="col-name">@v.FullNameTh</td>
                    <td class="col-type">@VehicleTypeLabel(v.VehicleType)</td>
                    <td class="col-card">@CardTypeLabel(v.CardType)</td>
                    <td class="col-plate cell-plate" data-plate="@v.LicensePlate">
                        <span class="plate-text">@v.LicensePlate</span>
                    </td>
                    <td class="col-province">@(v.LicenseProvince ?? "")</td>
                    <td class="col-brand">@(v.Brand ?? "")</td>
                    <td class="col-model">@(v.Model ?? "")</td>
                    <td class="col-color">@(v.Color ?? "")</td>
                    <td class="col-actions">
                        <button type="button" class="btn-del-row" aria-label="Delete">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="add-modal" class="modal-backdrop" hidden>
    <div class="modal-panel" role="dialog" aria-label="Add vehicle">
        <h2>Add vehicle</h2>
        <div class="form-row"><label>Employee code <input type="text" id="add-code" maxlength="50" /></label></div>
        <div class="form-row">
            <label>Type
                <select id="add-type">
                    <option value="C">Car</option>
                    <option value="M">Motorcycle</option>
                </select>
            </label>
            <label>Card
                <select id="add-card">
                    <option value="M">Monthly</option>
                    <option value="H">Hourly</option>
                </select>
            </label>
        </div>
        <div class="form-row"><label>Plate <input type="text" id="add-plate" maxlength="20" /></label></div>
        <div class="modal-actions">
            <button type="button" id="add-cancel" class="btn-secondary">Cancel</button>
            <button type="button" id="add-save" class="btn-primary">Add</button>
        </div>
    </div>
</div>

@functions {
    private static string VehicleTypeLabel(string? code) => code switch
    {
        "C" => "Car",
        "M" => "Motorcycle",
        _ => code ?? string.Empty
    };

    private static string CardTypeLabel(string? code) => code switch
    {
        "M" => "Monthly",
        "H" => "Hourly",
        null => string.Empty,
        _ => code
    };
}

<script>
    (function () {
        var table = document.getElementById('vehicle-table');
        var input = document.getElementById('vehicle-filter');
        var counter = document.getElementById('vehicle-filter-count');
        var status = document.getElementById('vehicle-status');
        var rows = function () { return table.querySelectorAll('tbody tr'); };

        function setStatus(msg, kind) {
            status.textContent = msg || '';
            status.className = 'owner-status' + (kind ? ' status-' + kind : '');
            if (msg) {
                clearTimeout(setStatus._t);
                setStatus._t = setTimeout(function () { status.textContent = ''; status.className = 'owner-status'; }, 4000);
            }
        }

        function refreshFilter() {
            var q = input.value.trim().toLowerCase();
            var all = rows();
            var visible = 0;
            all.forEach(function (row) {
                if (q === '') { row.style.display = ''; visible++; return; }
                var text = row.textContent.toLowerCase();
                var match = text.indexOf(q) !== -1;
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            counter.textContent = visible + ' of ' + all.length + ' shown';
        }
        input.addEventListener('input', refreshFilter);

        async function postJson(handler, payload) {
            var res = await fetch('?handler=' + handler, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            var data = null;
            try { data = await res.json(); } catch (e) { /* empty body ok */ }
            if (!res.ok) {
                throw new Error((data && data.error) || ('HTTP ' + res.status));
            }
            return data || {};
        }

        function enterEditPlate(cell) {
            if (cell.classList.contains('editing')) return;
            var oldPlate = cell.dataset.plate;
            cell.classList.add('editing');
            cell.innerHTML =
                '<div class="cell-edit-inline">' +
                  '<input type="text" class="plate-input" maxlength="20" />' +
                  '<button type="button" class="btn-save">Save</button>' +
                  '<button type="button" class="btn-cancel">Cancel</button>' +
                '</div>';
            var inp = cell.querySelector('.plate-input');
            inp.value = oldPlate;
            inp.focus();
            inp.select();

            function revert() {
                cell.classList.remove('editing');
                cell.innerHTML = '<span class="plate-text"></span>';
                cell.querySelector('.plate-text').textContent = oldPlate;
            }

            cell.querySelector('.btn-cancel').addEventListener('click', revert);
            cell.querySelector('.btn-save').addEventListener('click', async function () {
                var newPlate = inp.value.trim();
                if (!newPlate) { setStatus('Plate cannot be empty.', 'err'); return; }
                if (newPlate === oldPlate) { revert(); return; }
                var id = cell.closest('tr').dataset.id;
                try {
                    var data = await postJson('Update', { id: id, newPlate: newPlate });
                    cell.classList.remove('editing');
                    cell.dataset.plate = data.plate || newPlate;
                    cell.innerHTML = '<span class="plate-text"></span>';
                    cell.querySelector('.plate-text').textContent = data.plate || newPlate;
                    setStatus('Updated ' + oldPlate + ' → ' + (data.plate || newPlate), 'ok');
                } catch (err) {
                    setStatus(err.message, 'err');
                }
            });
            inp.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') cell.querySelector('.btn-save').click();
                if (e.key === 'Escape') revert();
            });
        }

        table.addEventListener('click', async function (e) {
            var delBtn = e.target.closest('.btn-del-row');
            if (delBtn) {
                var row = delBtn.closest('tr');
                var plate = row.querySelector('.col-plate').dataset.plate;
                if (!confirm('Delete plate ' + plate + ' for employee ' + row.dataset.employeeCode + '?')) return;
                try {
                    await postJson('Delete', { id: row.dataset.id });
                    row.remove();
                    setStatus('Deleted ' + plate, 'ok');
                    refreshFilter();
                } catch (err) {
                    setStatus(err.message, 'err');
                }
                return;
            }
            var cell = e.target.closest('td.col-plate');
            if (cell && !cell.classList.contains('editing')) {
                enterEditPlate(cell);
            }
        });

        // Add modal
        var modal = document.getElementById('add-modal');
        var addCode = document.getElementById('add-code');
        var addType = document.getElementById('add-type');
        var addCard = document.getElementById('add-card');
        var addPlate = document.getElementById('add-plate');

        function openModal() {
            addCode.value = ''; addType.value = 'C'; addCard.value = 'M'; addPlate.value = '';
            modal.hidden = false;
            addCode.focus();
        }
        function closeModal() { modal.hidden = true; }

        document.getElementById('btn-add-vehicle').addEventListener('click', openModal);
        document.getElementById('add-cancel').addEventListener('click', closeModal);
        modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
        document.getElementById('add-save').addEventListener('click', async function () {
            var payload = {
                employeeCode: addCode.value.trim(),
                vehicleType: addType.value,
                cardType: addCard.value,
                plate: addPlate.value.trim()
            };
            if (!payload.employeeCode || !payload.plate) {
                setStatus('Employee code and plate are required.', 'err');
                return;
            }
            try {
                await postJson('Insert', payload);
                setStatus('Added ' + payload.plate + ' for ' + payload.employeeCode + '. Reloading…', 'ok');
                closeModal();
                setTimeout(function () { window.location.reload(); }, 700);
            } catch (err) {
                setStatus(err.message, 'err');
            }
        });
    })();
</script>
