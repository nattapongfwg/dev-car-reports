@page
@model CarOwnersModel
@{
    ViewData["Title"] = "Car Owners";
}

<p><a asp-page="/Index" class="back-link">&larr; Back</a></p>

<div class="page-head">
    <h1>Car Owners</h1>
    <p class="lead">@Model.Owners.Count employees with at least one registered vehicle.</p>
</div>

<div class="table-toolbar">
    <input type="search" id="owner-filter" placeholder="Filter by code or name…" autocomplete="off" />
    <span id="owner-filter-count" class="filter-count">@Model.Owners.Count shown</span>
</div>

<div class="table-scroll">
    <table class="owner-table" id="owner-table">
        <thead>
            <tr class="group-row">
                <th rowspan="2" class="col-code">ID</th>
                <th rowspan="2" class="col-name">Full Name (TH)</th>
                <th rowspan="2" class="col-count">Total</th>
                <th colspan="4" class="group group-cm">Car / Monthly</th>
                <th colspan="3" class="group group-mm">Motor / Monthly</th>
                <th colspan="3" class="group group-ch">Car / Hourly</th>
                <th colspan="3" class="group group-mh">Motor / Hourly</th>
            </tr>
            <tr class="slot-row">
                <th>C-M 1</th><th>C-M 2</th><th>C-M 3</th><th class="group-end">C-M 4</th>
                <th>M-M 1</th><th>M-M 2</th><th class="group-end">M-M 3</th>
                <th>C-H 1</th><th>C-H 2</th><th class="group-end">C-H 3</th>
                <th>M-H 1</th><th>M-H 2</th><th class="group-end">M-H 3</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.Owners)
            {
                <tr>
                    <td class="col-code">@o.EmployeeCode</td>
                    <td class="col-name">@o.FullNameTh</td>
                    <td class="col-count">@o.TotalVehicles</td>
                    <td>@PlateCell(o.CM1)</td>
                    <td>@PlateCell(o.CM2)</td>
                    <td>@PlateCell(o.CM3)</td>
                    <td class="group-end">@PlateCell(o.CM4)</td>
                    <td>@PlateCell(o.MM1)</td>
                    <td>@PlateCell(o.MM2)</td>
                    <td class="group-end">@PlateCell(o.MM3)</td>
                    <td>@PlateCell(o.CH1)</td>
                    <td>@PlateCell(o.CH2)</td>
                    <td class="group-end">@PlateCell(o.CH3)</td>
                    <td>@PlateCell(o.MH1)</td>
                    <td>@PlateCell(o.MH2)</td>
                    <td class="group-end">@PlateCell(o.MH3)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@functions {
    private static Microsoft.AspNetCore.Html.IHtmlContent PlateCell(string? plate)
    {
        if (string.IsNullOrWhiteSpace(plate))
        {
            return new Microsoft.AspNetCore.Html.HtmlString("<span class=\"empty\">—</span>");
        }
        var encoded = Microsoft.AspNetCore.Html.HtmlString.Empty;
        return new Microsoft.AspNetCore.Html.HtmlString(System.Net.WebUtility.HtmlEncode(plate));
    }
}

<script>
    (function () {
        var input = document.getElementById('owner-filter');
        var counter = document.getElementById('owner-filter-count');
        var rows = document.querySelectorAll('#owner-table tbody tr');
        var total = rows.length;

        function refresh() {
            var q = input.value.trim().toLowerCase();
            var visible = 0;
            rows.forEach(function (row) {
                if (q === '') {
                    row.style.display = '';
                    visible++;
                    return;
                }
                var code = row.children[0].textContent.toLowerCase();
                var name = row.children[1].textContent.toLowerCase();
                var match = code.indexOf(q) !== -1 || name.indexOf(q) !== -1;
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            counter.textContent = visible + ' of ' + total + ' shown';
        }

        input.addEventListener('input', refresh);
    })();
</script>
