@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<h1>Car Reports</h1>
<p class="lead">Pick a report to generate.</p>

<div class="nav-card-row">
    <a class="nav-card" asp-page="/Salary">
        <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
                <path fill="#107C41" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <path fill="#185C37" d="M14 2v6h6z"/>
                <text x="12" y="17" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="7" font-weight="700" fill="#FFFFFF">XLS</text>
            </svg>
        </span>
        <span class="nav-card-body">
            <span class="nav-card-title">Employee Salary</span>
            <span class="nav-card-sub">Monthly salary deduction report from vehicle stamps + phone bill.</span>
        </span>
    </a>

    <a class="nav-card" asp-page="/Accounting">
        <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
                <path fill="#107C41" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <path fill="#185C37" d="M14 2v6h6z"/>
                <text x="12" y="17" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="7" font-weight="700" fill="#FFFFFF">XLS</text>
            </svg>
        </span>
        <span class="nav-card-body">
            <span class="nav-card-title">Accounting</span>
            <span class="nav-card-sub">Coming soon.</span>
        </span>
    </a>
</div>
